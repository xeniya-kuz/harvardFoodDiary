# Telegram Bot Token (получить у @BotFather в Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key (получить на https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here


# PostgreSQL подключение (Railway: скопировать из Variables сервиса PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Таймзона для отображения времени (список: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TIMEZONE=Europe/Moscow
